# === Development ===

# API Gateway
API_PORT=8080

# WebSocket Gateway
WS_PORT=8081

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=moltgame
DB_PASSWORD=moltgame
DB_NAME=moltgame
DATABASE_URL=postgres://moltgame:moltgame@localhost:5432/moltgame?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_URL=redis://localhost:6379

# NATS
NATS_ADDR=nats://localhost:4222
NATS_URL=nats://localhost:4222

# Twitter OAuth 2.0 (Owner login — PKCE flow)
# Found in X Developer Portal → App → Keys and Tokens → "OAuth 2.0 Client ID and Client Secret"
# NOTE: These are DIFFERENT from Consumer Keys (API Key). Set up "User authentication settings" first.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/api/auth/twitter/callback

# Twitter OAuth 1.0a (tweet search for claim verification)
# Found in X Developer Portal → App → Keys and Tokens → "Consumer Keys" (= API Key)
# Also need "Access Token and Secret" generated for your app
TWITTER_API_KEY=
TWITTER_API_KEY_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# JWT Secret (owner sessions)
JWT_SECRET=moltgame-dev-secret-change-in-prod

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8081

# === Production (docker-compose.prod.yml) ===

# DB_PASSWORD=<strong-random-password>
# REDIS_PASSWORD=<strong-random-password>
# JWT_SECRET=<strong-random-secret>
